{
  "name": "fabstack-forge",
  "version": "0.1.0-dev",
  "type": "module",
  "description": "Autonomous AI coder driven by runtime observability signals",
  "license": "MIT",
  "author": "Sergej Enenko",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sergej-enenko/fabstack-forge.git"
  },
  "private": true,
  "scripts": {
    "test": "bash -c \"node --test tests/unit/*.test.mjs tests/components/*.test.mjs 2>/dev/null || node --test tests/unit/*.test.mjs\"",
    "test:unit": "bash -c \"node --test tests/unit/*.test.mjs\"",
    "test:components": "bash -c \"node --test tests/components/*.test.mjs\"",
    "test:e2e": "bash -c \"node --test tests/e2e/*.test.mjs\"",
    "test:all": "npm run test:unit && npm run test:components && npm run test:e2e",
    "test:watch": "bash -c \"node --test --watch tests/unit/*.test.mjs\"",
    "lint": "node --check skills/log-monitor/scripts/*.mjs skills/log-monitor/scripts/classifier-rules/*.mjs"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.40.0",
    "@octokit/rest": "^21.0.0",
    "js-yaml": "^4.1.0"
  },
  "devDependencies": {}
}
